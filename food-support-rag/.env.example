# FastAPI configuration
PORT=8000

# OpenAI API credentials
OPENAI_API_KEY=your_openai_api_key_here
# Dòng máy học/ngôn ngữ sử dụng làm LLM và tạo vector
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-large

# Qdrant Database configuration
# - Đối với chạy local (Docker Compose): http://localhost:6333
# - Đối với Qdrant Cloud: https://xxxx-xxxx.aws.qdrant.io:6333
QDRANT_URL=http://localhost:6333
# API Key của Qdrant Cloud (Để trống nếu dùng docker local không cấu hình password)
QDRANT_API_KEY=

# Tên Collection lưu trữ các vector chunk
QDRANT_COLLECTION_NAME=knowledge_base
